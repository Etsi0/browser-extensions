{
	"manifest_version": 3,
	"name": "Sleepy Tabs",
	"version": "1.0.20260717",
	"description": "Sleepy Tabs automatically unloads inactive tabs after a set amount of time to free up memory",
	"permissions": [
		"tabs",
		"storage",
		"alarms"
	],
	"action": {
		"default_popup": "./index.html",
		"default_icon": {
			"16": "./Sleepy-tabs-16.png",
			"32": "./Sleepy-tabs-32.png",
			"64": "./Sleepy-tabs-64.png",
			"128": "./Sleepy-tabs-128.png",
			"256": "./Sleepy-tabs-256.png"
		}
	},
	"browser_specific_settings": {
		"gecko": {
			"id": "sleepytabs@phadonia.com",
			"strict_min_version": "147.0",
			"data_collection_permissions": {
				"required": ["none"],
				"optional": []
			}
		}
	},
	"background": {
		"scripts": ["./src/background.js"],
		"type": "module"
	},
	"icons": {
		"16": "./Sleepy-tabs-16.png",
		"32": "./Sleepy-tabs-32.png",
		"64": "./Sleepy-tabs-64.png",
		"128": "./Sleepy-tabs-128.png",
		"256": "./Sleepy-tabs-256.png"
	}
}
