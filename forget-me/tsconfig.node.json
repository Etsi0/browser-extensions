{
	"compilerOptions": {
		"tsBuildInfoFile": "node_modules/.tmp/tsconfig.node.tsbuildinfo",
		"target": "ES2024",
		"lib": ["esnext"],
		"skipLibCheck": true,
		"strict": true,
		"noEmit": true,
		"esModuleInterop": true,
		"module": "esnext",
		"moduleResolution": "bundler",
		"resolveJsonModule": true,
		"isolatedModules": true,
		"incremental": true,
		"types": ["node"]
	},
	"include": ["vite.config.ts"],
	"exclude": ["node_modules"]
}
